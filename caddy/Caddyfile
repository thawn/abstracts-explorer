# Caddyfile for Abstracts Explorer — Let's Encrypt variant
#
# Caddy automatically obtains and renews TLS certificates from Let's Encrypt.
# No manual Certbot steps are required: on first startup Caddy issues the
# certificate and stores it in the abstracts-caddy-data volume.
#
# Both HTTP and HTTPS traffic arrives on port 8080 via the system-level
# socket proxy (abstracts-web.socket + abstracts-web-proxy.service).
# Caddy auto-detects TLS vs. plain-HTTP connections and redirects HTTP to HTTPS.
#
# Before using this file:
#   1. Replace "abstracts.example.com" with your actual domain name.
#   2. Replace "your@email.com" with your email address (used for ACME registration
#      and expiry notifications from Let's Encrypt).
#   3. Ensure ports 80 and 443 are reachable from the internet (required for the
#      ACME HTTP-01 challenge).
#
# Copy this file to ~/abstracts-explorer/caddy/Caddyfile on the server.

{
    # Both HTTP and HTTPS share a single port — the system socket proxy
    # forwards port 80 and 443 to 8080.  Caddy auto-detects the protocol
    # by peeking at the first bytes of each connection (TLS ClientHello vs.
    # plain HTTP) and handles both TLS termination and HTTP→HTTPS redirect
    # on this single port.
    http_port  8080
    https_port 8080

    # Email for ACME account registration and certificate expiry notifications.
    email your@email.com
}

abstracts.example.com {
    # Proxy all requests to the Abstracts Explorer application container.
    reverse_proxy abstracts-explorer:5000 {
        header_up Host             {host}
        header_up X-Real-IP        {remote_host}
        header_up X-Forwarded-For  {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    # Security headers
    header {
        Strict-Transport-Security  "max-age=63072000; includeSubDomains"
        X-Content-Type-Options     "nosniff"
        X-Frame-Options            "SAMEORIGIN"
        Referrer-Policy            "strict-origin-when-cross-origin"
        X-XSS-Protection           "1; mode=block"
        Content-Security-Policy    "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self'; frame-ancestors 'none'; object-src 'none'; base-uri 'self';"
        Permissions-Policy         "camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()"
        # Strip implementation-detail headers from upstream responses.
        -Server
        -X-Powered-By
        # Restrict CORS to same-origin only (suppress the upstream wildcard).
        -Access-Control-Allow-Origin
        -Access-Control-Allow-Credentials
        -Access-Control-Allow-Methods
        -Access-Control-Allow-Headers
    }

    # TLS configuration — Caddy manages certificate issuance automatically.
    tls {
        protocols tls1.3
    }
}
