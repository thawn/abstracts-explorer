# Abstracts Explorer — environment configuration
# This file is loaded by the abstracts-explorer.container quadlet.
# Copy it to ~/abstracts-explorer/abstracts-explorer.env and edit as needed.
#
# API tokens (LLM_BACKEND_AUTH_TOKEN, GITHUB_TOKEN) are injected via Podman
# secrets and must NOT be placed here.
#
# The database password appears in the PAPER_DB connection string below.
# It is auto-generated by the install script and is only used within the
# internal container network.  Keep this file readable only by your user
# (chmod 600).

# --- Application data directory (inside the container) ---
DATA_DIR=/app/data

# --- PostgreSQL connection ---
# The password in this connection string must match the postgres-password
# Podman secret.  The install script sets both automatically.
PAPER_DB=postgresql://abstracts:change_me_in_production@abstracts-postgres:5432/abstracts

# --- ChromaDB vector database ---
EMBEDDING_DB=http://abstracts-chromadb:8000
COLLECTION_NAME=papers

# --- LLM backend ---
# Blablador (default):
LLM_BACKEND_URL=https://api.helmholtz-blablador.fz-juelich.de
# LM Studio on the host (uncomment):
# LLM_BACKEND_URL=http://host.containers.internal:1234

# --- Model names ---
# Blablador defaults:
CHAT_MODEL=alias-code
EMBEDDING_MODEL=alias-qwen3-8b-embeddings
# LM Studio (uncomment):
# CHAT_MODEL=gemma-3-4b-it-qat
# EMBEDDING_MODEL=text-embedding-qwen3-embedding-4b

# --- RAG settings ---
MAX_CONTEXT_PAPERS=5
ENABLE_QUERY_REWRITING=true
QUERY_SIMILARITY_THRESHOLD=0.7

# --- Logging (DEBUG, INFO, WARNING, ERROR, CRITICAL) ---
LOG_LEVEL=WARNING

# --- Reverse-proxy hop counts (1 for nginx/Caddy) ---
PROXY_X_FOR=1
PROXY_X_PROTO=1
PROXY_X_HOST=1
PROXY_X_PREFIX=1

# --- OCI Registry (optional — uncomment and create github-token secret) ---
# REGISTRY_REPOSITORY=ghcr.io/thawn/abstracts-data
